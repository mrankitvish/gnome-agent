# Gnome Agent Runtime — environment configuration
# Copy this to .env and adjust as needed.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: ollama | openai | openai_compatible
GNOME_AGENT_DEFAULT_LLM_PROVIDER=openai_compatible
GNOME_AGENT_DEFAULT_LLM_MODEL=mistral

# ── Ollama (local, no API key needed) ─────────────────────────────────────────
GNOME_AGENT_OLLAMA_BASE_URL=http://localhost:11434

# ── OpenAI ────────────────────────────────────────────────────────────────────
# GNOME_AGENT_DEFAULT_LLM_PROVIDER=openai
# GNOME_AGENT_DEFAULT_LLM_MODEL=gpt-4o-mini
# GNOME_AGENT_OPENAI_API_KEY=sk-...

# ── OpenAI-Compatible (LM Studio, vLLM, Jan, Ollama /v1, llama-cpp-server) ────
# Point BASE_URL at your server's /v1 endpoint.
# Most local servers accept any string as the API key.
GNOME_AGENT_OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
GNOME_AGENT_OPENAI_COMPATIBLE_API_KEY=not-needed

# ── Database ──────────────────────────────────────────────────────────────────
GNOME_AGENT_DATABASE_PATH=gnome_agent.db

# ── Agent Guardrails ──────────────────────────────────────────────────────────
GNOME_AGENT_MAX_ITERATIONS=6
GNOME_AGENT_MAX_TOOL_CALLS=10

# ── Server ────────────────────────────────────────────────────────────────────
GNOME_AGENT_HOST=127.0.0.1
GNOME_AGENT_PORT=8000

# ── Auth (optional) ───────────────────────────────────────────────────────────
# Set to enable Bearer token auth: Authorization: Bearer <your-key>
# Leave empty to disable auth (default for local dev)
# GNOME_AGENT_API_KEY=your-secret-key-here

# ── Rate Limiting (optional) ──────────────────────────────────────────────────
# Max requests per minute per IP — 0 = disabled
# GNOME_AGENT_RATE_LIMIT_RPM=60

# ── Built-in MCP Servers ──────────────────────────────────────────────────────
GNOME_AGENT_ENABLE_BUILTIN_SERVERS=false
